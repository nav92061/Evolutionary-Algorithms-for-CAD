   "source": [
    "# ---
",
    "# CELL 6: Genetic Algorithm — Genome Design\n",
    "# ---
",
    "# Each individual = list of floats [0,1] with length:\n",
    "#   [0 .. N_FEATURES-1]  → feature mask (>0.5 = include)\n",
    "#   [N_FEATURES]         → n_estimators  gene  (mapped 50–400)\n",
    "#   [N_FEATURES+1]       → max_depth     gene  (mapped 2–10)\n",
    "#   [N_FEATURES+2]       → learning_rate gene  (mapped 0.01–0.3)\n",
    "#   [N_FEATURES+3]       → subsample     gene  (mapped 0.5–1.0)\n",
    "\n",
    "GENOME_LEN = N_FEATURES + 4\n",
    "\n",
    "def decode_individual(ind):\n",
    "    \"\"\"Map float genes → usable feature mask + hyperparameters.\"\"\"\n",
    "    feature_mask   = [g > 0.5 for g in ind[:N_FEATURES]]\n",
    "    n_estimators   = int(50  + ind[N_FEATURES]   * 350)   # 50–400\n",
    "    max_depth      = int(2   + ind[N_FEATURES+1] * 8)     # 2–10\n",
    "    learning_rate  = 0.01 + ind[N_FEATURES+2]   * 0.29   # 0.01–0.30\n",
    "    subsample      = 0.5  + ind[N_FEATURES+3]   * 0.5    # 0.5–1.0\n",
    "    return feature_mask, n_estimators, max_depth, learning_rate, subsample\n",
    "\n",
    "CV = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "\n",
    "def fitness(individual):\n",
    "    \"\"\"Fitness = mean 5-fold ROC-AUC. Penalise trivial (all-False) masks.\"\"\"\n",
    "    mask, n_est, depth, lr, sub = decode_individual(individual)\n",
    "    if sum(mask) < 2:           # need at least 2 features\n",
    "        return (0.5,)\n",
    "    X_sel = X_sc[:, mask]\n",
    "    clf   = GradientBoostingClassifier(\n",
    "        n_estimators=n_est, max_depth=depth,\n",
    "        learning_rate=lr, subsample=sub,\n",
    "        random_state=42\n",
    "    )\n",
    "    scores = cross_val_score(clf, X_sel, y, cv=CV, scoring='roc_auc', n_jobs=-1)\n",
    "    return (scores.mean(),)\n",
    "\n",
    "print(f'Genome length : {GENOME_LEN}')\n",
    "print('Fitness function: 5-fold ROC-AUC (GradientBoosting)')"
   ]
