    "# ---
",
    "# CELL 11: Final Model Evaluation\n",
    "# ---
",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "X_sel = X_sc[:, mask]\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_sel, y, test_size=0.2, stratify=y, random_state=42)\n",
    "\n",
    "final_clf = GradientBoostingClassifier(\n",
    "    n_estimators=n_est, max_depth=depth,\n",
    "    learning_rate=lr, subsample=sub, random_state=42)\n",
    "\n",
    "final_clf.fit(X_train, y_train)\n",
    "y_pred  = final_clf.predict(X_test)\n",
    "y_proba = final_clf.predict_proba(X_test)[:, 1]\n",
    "\n",
    "auc = roc_auc_score(y_test, y_proba)\n",
    "print(f'\\n Test ROC-AUC : {auc:.4f}')\n",
    "print('\\nClassification Report:')\n",
    "print(classification_report(y_test, y_pred, target_names=['Healthy','Unhealthy']))\n",
    "\n",
    "# Plots\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
    "\n",
    "# ROC curve\n",
    "RocCurveDisplay.from_predictions(y_test, y_proba, ax=axes[0],\n",
    "    name=f'Evolved GBM (AUC={auc:.3f})', color='steelblue')\n",
    "axes[0].plot([0,1],[0,1],'k--', lw=1)\n",
    "axes[0].set_title('ROC Curve — Evolved Model', fontweight='bold')\n",
    "\n",
    "# Confusion matrix\n",
